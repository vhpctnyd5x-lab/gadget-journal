# Vercel Production Environment Variables
# Copy this file to .env.local and fill in the values for production

# Application
NEXT_PUBLIC_APP_NAME=Gadget Journal
NEXT_PUBLIC_APP_URL=https://gadget-journal.vercel.app
NEXT_PUBLIC_ENVIRONMENT=production

# Analytics & Monitoring
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=

# API Configuration
NEXT_PUBLIC_API_ENDPOINT=https://api.gadget-journal.com
API_SECRET_KEY=

# CDN & Storage
NEXT_PUBLIC_CDN_URL=https://cdn.gadget-journal.com
NEXT_PUBLIC_IMAGE_DOMAINS=images.gadget-journal.com,cdn.gadget-journal.com

# Security
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://gadget-journal.vercel.app

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_COMMENTS=false
NEXT_PUBLIC_MAINTENANCE_MODE=false
